---
import type { Translations } from '../i18n/types';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const isUa = t.lang === 'ua' || t.lang === 'uk';
const pageTitle = isUa
  ? '20K Productions — Студія голосового запису у Львові'
  : '20K Productions — Voice Recording Studio in Lviv';
const pageDesc = isUa
  ? 'Студія голосового запису у Львові. Запис вокалу, аудіокниг, подкастів, озвучки, саунд дизайн, джингли.'
  : 'Voice Recording Studio in Lviv. Vocal recording, audiobooks, podcasts, dubbing, sound design, jingles.';
---

<!DOCTYPE html>
<html lang={t.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="alternate" hreflang="ua" href="/" />
    <link rel="alternate" hreflang="en" href="/en/" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="bg-zinc-950 text-white font-sans antialiased">
    <Header t={t} />
    <main>
      <slot />
    </main>
    <Footer t={t} />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #09090b;
  }
  ::-webkit-scrollbar-thumb {
    background: #d4a847;
    border-radius: 3px;
  }

  ::selection {
    background: #d4a847;
    color: #09090b;
  }
</style>
