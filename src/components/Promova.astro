---
import type { Translations } from '../i18n/types';

import videoCover from '@assets/images/video-cover.jpg'

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="promova" class="relative py-28 lg:py-36 bg-zinc-900">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-400/20 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <!-- Text side -->
      <div>
        <p class="text-gold-400 text-[10px] tracking-[0.5em] uppercase font-heading mb-3">Partnership</p>
        <h2 class="font-heading font-black text-4xl sm:text-5xl text-white tracking-tight leading-tight mb-4">
          {t.promova.title}
        </h2>
        <p class="text-gold-400/80 font-heading text-sm tracking-wide mb-6">{t.promova.subtitle}</p>
        <div class="h-px w-16 bg-gold-400 mb-8"></div>
        <p class="text-zinc-400 leading-relaxed mb-10">{t.promova.text}</p>

        <a
          href="https://www.youtube.com/@projektmova"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-[#FF0000] hover:bg-[#cc0000] text-white px-6 py-3 rounded-lg font-heading font-bold text-sm tracking-wide transition-colors"
        >
          <!-- YouTube icon -->
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          {t.promova.cta}
        </a>
      </div>

      <div>
        <video
            type="video/mp4"
            controls
            loading="lazy"
            playsinline
            loop
            src="/videos/video.mp4"
            poster={videoCover.src}
            class="w-full mx-auto rounded-2xl shadow-2xl shadow-black/50"
        ></video>
      </div>



    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-400/20 to-transparent"></div>
</section>
