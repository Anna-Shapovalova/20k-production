---
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

// Waveform shape: low → high → low
const bars = [
  { maxH: 10, dur: '1.1s', del: '0.00s' },
  { maxH: 18, dur: '0.8s', del: '0.05s' },
  { maxH: 30, dur: '1.3s', del: '0.10s' },
  { maxH: 44, dur: '0.9s', del: '0.15s' },
  { maxH: 56, dur: '1.4s', del: '0.05s' },
  { maxH: 64, dur: '1.0s', del: '0.20s' },
  { maxH: 70, dur: '1.2s', del: '0.10s' },
  { maxH: 74, dur: '0.85s', del: '0.00s' },
  { maxH: 68, dur: '1.3s', del: '0.15s' },
  { maxH: 76, dur: '1.1s', del: '0.25s' },
  { maxH: 68, dur: '0.9s', del: '0.05s' },
  { maxH: 74, dur: '1.4s', del: '0.10s' },
  { maxH: 76, dur: '1.0s', del: '0.20s' },
  { maxH: 74, dur: '1.2s', del: '0.00s' },
  { maxH: 68, dur: '0.85s', del: '0.15s' },
  { maxH: 76, dur: '1.1s', del: '0.10s' },
  { maxH: 68, dur: '1.3s', del: '0.25s' },
  { maxH: 74, dur: '0.9s', del: '0.05s' },
  { maxH: 70, dur: '1.4s', del: '0.00s' },
  { maxH: 64, dur: '1.0s', del: '0.15s' },
  { maxH: 56, dur: '1.2s', del: '0.10s' },
  { maxH: 44, dur: '0.85s', del: '0.20s' },
  { maxH: 30, dur: '1.3s', del: '0.05s' },
  { maxH: 18, dur: '1.1s', del: '0.10s' },
  { maxH: 10, dur: '0.9s', del: '0.00s' },
];
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-zinc-950 via-zinc-950 to-zinc-900/80"></div>
  <!-- Subtle grid -->
  <div class="absolute inset-0 opacity-30"
    style="background-image: linear-gradient(rgba(212,168,71,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(212,168,71,0.06) 1px, transparent 1px); background-size: 80px 80px;">
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center text-center px-4 mt-10">
    <img src="/logo.svg" alt="20K Productions" class="w-44 md:w-96 h-auto" />

    <p class="hero-up text-zinc-500 text-sm sm:text-base font-light tracking-[0.3em] uppercase mt-14 mb-10"
       style="animation-delay: 0.1s">
      {t.hero.subtitle}
    </p>

    <!-- Waveform -->
    <div class="flex items-end gap-1 mb-14 h-24">
      {bars.map(b => (
        <div
          class="wave-bar w-[3px] rounded-full bg-zinc-300 opacity-70"
          style={`animation: wave-anim ${b.dur} ease-in-out ${b.del} infinite alternate; --mh: ${b.maxH}px;`}
        />
      ))}
    </div>

    <!-- Scroll CTA -->
    <a href="#about" class="hero-up flex flex-col items-center gap-2 text-zinc-600 hover:text-gold-400 transition-colors group"
       style="animation-delay: 0.2s">
      <span class="text-[10px] tracking-[0.4em] uppercase">{t.hero.cta}</span>
      <svg class="w-4 h-4 group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .wave-bar {
    height: 4px;
    animation: wave-anim 1s ease-in-out infinite alternate;
  }

  @keyframes wave-anim {
    from { height: 4px; }
    to   { height: var(--mh, 40px); }
  }

  .hero-fade {
    animation: fade-in 1.2s ease-out both;
  }

  .hero-up {
    animation: fade-up 0.9s ease-out both;
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
