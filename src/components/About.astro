---
import {Image} from "astro:assets";
import type { Translations } from '../i18n/types';
import aboutUs from '@assets/images/about-us.jpeg'

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" class="relative py-28 lg:py-36 bg-zinc-900">
  <!-- Decorative top border -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-400/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Text -->
      <div>
        <div class="mb-10">
          <p class="text-gold-400 text-[10px] tracking-[0.5em] uppercase font-heading mb-3">Studio</p>
          <h2 class="font-heading font-black text-4xl sm:text-5xl text-white tracking-tight">
            {t.about.title}
          </h2>
          <div class="mt-4 h-px w-16 bg-gold-400"></div>
        </div>

        <div class="space-y-5">
          {t.about.paragraphs.map((p, i) => (
            <p class={`leading-relaxed ${i === 0 ? 'text-white text-lg font-medium' : 'text-zinc-400'}`}>
              {p}
            </p>
          ))}
        </div>

        <a
          href="#contact"
          class="inline-flex items-center gap-2 mt-10 text-xs font-heading font-bold tracking-widest uppercase text-gold-400 hover:text-gold-500 transition-colors group"
        >
          {t.nav.contact}
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Decorative waveform panel -->
      <div class="hidden lg:flex items-center justify-center">
        <div class="relative w-full">
          <!-- Outer glow frame -->
          <div class="absolute -inset-4 rounded-2xl bg-gold-400/5 blur-xl"></div>
          <div class="relative rounded-2xl border border-zinc-800 flex items-center justify-center">
            <Image src={aboutUs} alt="20K Productions" class="w-full rounded-2xl" />
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Decorative bottom border -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-400/20 to-transparent"></div>
</section>

<style>
  .wave-deco {
    animation: pulse-height 2s ease-in-out infinite alternate;
  }
  @keyframes pulse-height {
    from { opacity: 0.5; transform: scaleY(0.85); }
    to   { opacity: 1;   transform: scaleY(1); }
  }
</style>
